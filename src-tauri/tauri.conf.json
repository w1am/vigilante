{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vigilante",
  "version": "0.1.1",
  "identifier": "io.github.w1am.vigilante",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "npm run sass",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vigilante",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "nsis",
      "dmg"
    ],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
