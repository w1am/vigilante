{
  "name": "vigilante",
  "version": "0.1.0-alpha.1",
  "description": "RTSP stream viewer",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "sass": "sass src/renderer/styles/main.sass src/renderer/styles/main.css",
    "sass:watch": "sass --watch src/renderer/styles/main.sass src/renderer/styles/main.css",
    "start": "bun run sass && ELECTRON_DISABLE_SANDBOX=1 electron .",
    "dist": "bun run sass && electron-builder",
    "dist:win": "bun run sass && electron-builder --win",
    "dist:linux": "bun run sass && electron-builder --linux",
    "dist:mac": "bun run sass && electron-builder --mac"
  },
  "keywords": [],
  "author": "William Chong <admin@email.com>",
  "homepage": "https://github.com/w1am/vigilante",
  "repository": {
    "type": "git",
    "url": "https://github.com/w1am/vigilante.git"
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "sass": "^1.97.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "rtsp-relay": "^1.9.0",
    "xel": "^0.39.7"
  }
}
